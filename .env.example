# Copy this file to .env and fill in your Supabase project's values
# (Project Settings → API in the Supabase dashboard).
#
# The anon key is safe to expose in a client bundle by design — every table
# and storage bucket it can touch is locked down by Row Level Security
# (see supabase/schema.sql). Never put the service_role key here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
